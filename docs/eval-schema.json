{
  "$defs": {
    "nonEmptyString": {
      "minLength": 1,
      "pattern": "\\S",
      "type": "string"
    },
    "nonEmptyStringArray": {
      "items": {
        "$ref": "#/$defs/nonEmptyString"
      },
      "minItems": 1,
      "type": "array"
    },
    "runnerAssertionObject": {
      "additionalProperties": false,
      "oneOf": [
        {
          "required": [
            "contains"
          ]
        },
        {
          "required": [
            "not_contains"
          ]
        },
        {
          "required": [
            "any_contains"
          ]
        },
        {
          "required": [
            "all_contains"
          ]
        }
      ],
      "properties": {
        "all_contains": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "any_contains": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "contains": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "not_contains": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "target": {
          "default": "output",
          "enum": [
            "output",
            "text"
          ],
          "type": "string"
        }
      },
      "type": "object"
    },
    "runnerTest": {
      "additionalProperties": false,
      "properties": {
        "assertions": {
          "items": {
            "anyOf": [
              {
                "$ref": "#/$defs/nonEmptyString"
              },
              {
                "$ref": "#/$defs/runnerAssertionObject"
              }
            ]
          },
          "minItems": 1,
          "type": "array"
        },
        "baseline_assertions": {
          "items": {
            "anyOf": [
              {
                "$ref": "#/$defs/nonEmptyString"
              },
              {
                "$ref": "#/$defs/runnerAssertionObject"
              }
            ]
          },
          "type": "array"
        },
        "id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "min_score_delta": {
          "minimum": 0,
          "type": "integer"
        },
        "prompt": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "require_improvement": {
          "default": true,
          "type": "boolean"
        }
      },
      "required": [
        "id",
        "prompt",
        "assertions"
      ],
      "type": "object"
    },
    "skillAssertionObject": {
      "additionalProperties": false,
      "oneOf": [
        {
          "required": [
            "contains"
          ]
        },
        {
          "required": [
            "not_contains"
          ]
        },
        {
          "required": [
            "any_contains"
          ]
        },
        {
          "required": [
            "all_contains"
          ]
        }
      ],
      "properties": {
        "all_contains": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "any_contains": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "contains": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "not_contains": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "target": {
          "default": "text",
          "enum": [
            "text",
            "description",
            "body"
          ],
          "type": "string"
        }
      },
      "type": "object"
    },
    "taskTest": {
      "additionalProperties": false,
      "properties": {
        "assertions": {
          "items": {
            "anyOf": [
              {
                "$ref": "#/$defs/nonEmptyString"
              },
              {
                "$ref": "#/$defs/skillAssertionObject"
              }
            ]
          },
          "minItems": 1,
          "type": "array"
        },
        "id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "prompt": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "assertions"
      ],
      "type": "object"
    },
    "triggerTest": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "keywords": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "negative_keywords": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "query": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "should_trigger": {
          "type": "boolean"
        }
      },
      "required": [
        "id",
        "query",
        "should_trigger"
      ],
      "type": "object"
    }
  },
  "$id": "https://github.com/MuzeAnisichael/agent-skill-factory/blob/main/docs/eval-schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "anyOf": [
    {
      "required": [
        "trigger_tests"
      ]
    },
    {
      "required": [
        "task_tests"
      ]
    },
    {
      "required": [
        "runner_tests"
      ]
    }
  ],
  "description": "Schema for <skill>/evals/evals.json files used by skill-factory eval.",
  "properties": {
    "runner_tests": {
      "items": {
        "$ref": "#/$defs/runnerTest"
      },
      "minItems": 1,
      "type": "array"
    },
    "task_tests": {
      "items": {
        "$ref": "#/$defs/taskTest"
      },
      "minItems": 1,
      "type": "array"
    },
    "trigger_tests": {
      "items": {
        "$ref": "#/$defs/triggerTest"
      },
      "minItems": 1,
      "type": "array"
    }
  },
  "title": "Agent Skill Factory Eval File",
  "type": "object"
}
